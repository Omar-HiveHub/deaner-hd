# Environment & secrets — never commit
config/.env

# Python
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Output files (large video, temp render)
outputs/long-form/*.mp4
outputs/shorts/*.mp4
pipeline/rendered/*.mp4
pipeline/recorded/*.m4a
pipeline/recorded/*.mp3
pipeline/recorded/*.wav

# Raw clips (large, re-gatherable)
clips/raw/

# Temp / work directories
pipeline/work/
*.tmp

# Whisper model cache
~/.cache/whisper/

# Jupyter / IDEs
.ipynb_checkpoints
.vscode/
*.code-workspace

# Partial downloads
*.part
*.webm.part

# Logs
*.log
